{% doc %}
  @prompt
    Create a premium luxury testimonial slider section for a jewelry brand that matches the attached reference design exactly in spacing, typography, card shape, and minimalist aesthetic.
    
    Section Header:
    
    Center-aligned heading: “Testimonials” using an elegant luxury serif font.
    Small muted subtitle underneath: “Loved by our community”.
    Add a thin turquoise accent line centered below the subtitle.
    
    Testimonial Slider Layout:
    
    Create a horizontally scrollable testimonial carousel/slider.
    Show 3 testimonial cards visible at once on desktop.
    Keep the exact card proportions, spacing, and alignment from the reference image.
    Cards should scroll smoothly horizontally.
    Add left and right navigation arrow icons/buttons on both sides of the slider.
    Navigation arrows should be:
    Minimal and premium looking
    Circular or subtle luxury style
    Positioned vertically centered beside the cards
    Clean without heavy shadows
    Elegant and modern for a luxury jewelry brand
    
    Card Design (Keep Exactly Same):
    
    Large rounded corner cards with a soft luxury shape.
    Background color: light warm beige/off-white.
    Center-aligned content.
    Top: 5 turquoise stars.
    Middle: customer review text in italic serif typography.
    Bottom:
    Customer name in clean sans-serif
    Small muted location text below
    
    Animation & Interaction:
    
    Smooth horizontal sliding transition.
    Clicking arrows moves testimonials one card at a time.
    Optional drag/swipe support on mobile.
    Infinite loop carousel for premium UX.
    
    Responsive Layout:
    
    Desktop: 3 cards visible.
    Tablet: 2 cards visible.
    Mobile: 1 card visible with swipe functionality.
    
    Design Direction:
    
    Keep the exact minimalist luxury aesthetic from the reference.
    Maintain generous white spacing and editorial elegance.
    Do not redesign the section — only make it scrollable and add elegant left/right navigation icons while preserving the exact original appearance.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-testimonial-slider-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-testimonial-slider__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-testimonial-slider__heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-style: {{ block.settings.heading_font.style }};
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.subtitle_spacing }}px;
    letter-spacing: 0.02em;
  }

  .ai-testimonial-slider__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0 0 {{ block.settings.accent_line_spacing }}px;
    font-weight: 400;
  }

  .ai-testimonial-slider__accent-line-{{ ai_gen_id }} {
    width: {{ block.settings.accent_line_width }}px;
    height: {{ block.settings.accent_line_height }}px;
    background-color: {{ block.settings.accent_color }};
    margin: 0 auto;
  }

  .ai-testimonial-slider__container-{{ ai_gen_id }} {
    position: relative;
    max-width: {{ block.settings.container_max_width }}px;
    margin: 0 auto;
    padding: 0 60px;
  }

  .ai-testimonial-slider__track-wrapper-{{ ai_gen_id }} {
    overflow: hidden;
    position: relative;
  }

  .ai-testimonial-slider__track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.card_gap }}px;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .ai-testimonial-slider__card-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - {{ block.settings.card_gap | times: 2 }}px) / 3);
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    min-height: {{ block.settings.card_min_height }}px;
  }

  .ai-testimonial-slider__stars-{{ ai_gen_id }} {
    display: flex;
    gap: 4px;
    margin-bottom: {{ block.settings.stars_spacing }}px;
  }

  .ai-testimonial-slider__star-{{ ai_gen_id }} {
    width: {{ block.settings.star_size }}px;
    height: {{ block.settings.star_size }}px;
    fill: {{ block.settings.star_color }};
  }

  .ai-testimonial-slider__text-{{ ai_gen_id }} {
    font-family: {{ block.settings.text_font.family }}, {{ block.settings.text_font.fallback_families }};
    font-weight: {{ block.settings.text_font.weight }};
    font-style: italic;
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
    color: {{ block.settings.text_color }};
    margin: 0 0 {{ block.settings.text_spacing }}px;
    flex-grow: 1;
  }

  .ai-testimonial-slider__author-{{ ai_gen_id }} {
    font-size: {{ block.settings.author_size }}px;
    font-weight: 500;
    color: {{ block.settings.author_color }};
    margin: 0 0 {{ block.settings.location_spacing }}px;
  }

  .ai-testimonial-slider__location-{{ ai_gen_id }} {
    font-size: {{ block.settings.location_size }}px;
    color: {{ block.settings.location_color }};
    margin: 0;
  }

  .ai-testimonial-slider__nav-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: {{ block.settings.nav_button_size }}px;
    height: {{ block.settings.nav_button_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.nav_button_background }};
    border: {{ block.settings.nav_button_border_width }}px solid {{ block.settings.nav_button_border }};
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
    z-index: 2;
  }

  .ai-testimonial-slider__nav-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.nav_button_hover_background }};
    border-color: {{ block.settings.nav_button_hover_border }};
  }

  .ai-testimonial-slider__nav-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-testimonial-slider__nav--prev-{{ ai_gen_id }} {
    left: 0;
  }

  .ai-testimonial-slider__nav--next-{{ ai_gen_id }} {
    right: 0;
  }

  .ai-testimonial-slider__nav-icon-{{ ai_gen_id }} {
    width: {{ block.settings.nav_icon_size }}px;
    height: {{ block.settings.nav_icon_size }}px;
    stroke: {{ block.settings.nav_icon_color }};
    stroke-width: 1.5;
  }

  .ai-testimonial-slider__nav-{{ ai_gen_id }}:hover .ai-testimonial-slider__nav-icon-{{ ai_gen_id }} {
    stroke: {{ block.settings.nav_icon_hover_color }};
  }

  @media screen and (max-width: 989px) {
    .ai-testimonial-slider__card-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - {{ block.settings.card_gap }}px) / 2);
    }

    .ai-testimonial-slider__container-{{ ai_gen_id }} {
      padding: 0 50px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-testimonial-slider__card-{{ ai_gen_id }} {
      flex: 0 0 100%;
    }

    .ai-testimonial-slider__container-{{ ai_gen_id }} {
      padding: 0 45px;
    }

    .ai-testimonial-slider__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-testimonial-slider__track-wrapper-{{ ai_gen_id }} {
      touch-action: pan-y;
    }
  }
{% endstyle %}

<luxury-testimonial-slider-{{ ai_gen_id }}
  class="ai-testimonial-slider-{{ ai_gen_id }}"
  data-infinite="{{ block.settings.infinite_loop }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-testimonial-slider__header-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-testimonial-slider__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}
    {% if block.settings.subtitle != blank %}
      <p class="ai-testimonial-slider__subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
    {% endif %}
    <div class="ai-testimonial-slider__accent-line-{{ ai_gen_id }}"></div>
  </div>

  <div class="ai-testimonial-slider__container-{{ ai_gen_id }}">
    <button
      class="ai-testimonial-slider__nav-{{ ai_gen_id }} ai-testimonial-slider__nav--prev-{{ ai_gen_id }}"
      aria-label="Previous testimonial"
      data-nav="prev"
    >
      <svg class="ai-testimonial-slider__nav-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none">
        <path d="M15 18L9 12L15 6" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

    <div class="ai-testimonial-slider__track-wrapper-{{ ai_gen_id }}">
      <div class="ai-testimonial-slider__track-{{ ai_gen_id }}">
        {% for i in (1..6) %}
          {% liquid
            assign testimonial_text_key = 'testimonial_' | append: i | append: '_text'
            assign testimonial_author_key = 'testimonial_' | append: i | append: '_author'
            assign testimonial_location_key = 'testimonial_' | append: i | append: '_location'
            assign testimonial_rating_key = 'testimonial_' | append: i | append: '_rating'

            assign testimonial_text = block.settings[testimonial_text_key]
            assign testimonial_author = block.settings[testimonial_author_key]
            assign testimonial_location = block.settings[testimonial_location_key]
            assign testimonial_rating = block.settings[testimonial_rating_key]
          %}

          {% if testimonial_text != blank or testimonial_author != blank %}
            <div class="ai-testimonial-slider__card-{{ ai_gen_id }}">
              <div class="ai-testimonial-slider__stars-{{ ai_gen_id }}">
                {% for star in (1..testimonial_rating) %}
                  <svg class="ai-testimonial-slider__star-{{ ai_gen_id }}" viewBox="0 0 24 24">
                    <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
                  </svg>
                {% endfor %}
              </div>

              <p class="ai-testimonial-slider__text-{{ ai_gen_id }}">
                {% if testimonial_text != blank %}
                  "{{ testimonial_text }}"
                {% else %}
                  "Add your customer testimonial here to showcase authentic reviews and build trust with potential buyers."
                {% endif %}
              </p>

              <p class="ai-testimonial-slider__author-{{ ai_gen_id }}">
                {% if testimonial_author != blank %}
                  {{ testimonial_author }}
                {% else %}
                  Customer Name
                {% endif %}
              </p>

              {% if testimonial_location != blank %}
                <p class="ai-testimonial-slider__location-{{ ai_gen_id }}">{{ testimonial_location }}</p>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>

    <button
      class="ai-testimonial-slider__nav-{{ ai_gen_id }} ai-testimonial-slider__nav--next-{{ ai_gen_id }}"
      aria-label="Next testimonial"
      data-nav="next"
    >
      <svg class="ai-testimonial-slider__nav-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none">
        <path d="M9 18L15 12L9 6" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </div>
</luxury-testimonial-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class LuxuryTestimonialSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.isInfinite = this.dataset.infinite === 'true';
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-testimonial-slider__track-{{ ai_gen_id }}');
        this.cards = this.querySelectorAll('.ai-testimonial-slider__card-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('[data-nav="prev"]');
        this.nextButton = this.querySelector('[data-nav="next"]');
        this.trackWrapper = this.querySelector('.ai-testimonial-slider__track-wrapper-{{ ai_gen_id }}');

        if (this.cards.length === 0) return;

        this.setupInfiniteLoop();
        this.setupEventListeners();
        this.updateSlider();
      }

      setupInfiniteLoop() {
        if (!this.isInfinite || this.cards.length < 3) return;

        const firstClones = Array.from(this.cards).slice(0, 3).map(card => card.cloneNode(true));
        const lastClones = Array.from(this.cards).slice(-3).map(card => card.cloneNode(true));

        lastClones.forEach(clone => this.track.insertBefore(clone, this.track.firstChild));
        firstClones.forEach(clone => this.track.appendChild(clone));

        this.currentIndex = 3;
        this.allCards = this.querySelectorAll('.ai-testimonial-slider__card-{{ ai_gen_id }}');
      }

      setupEventListeners() {
        this.prevButton.addEventListener('click', () => this.navigate('prev'));
        this.nextButton.addEventListener('click', () => this.navigate('next'));

        let startX = 0;
        let currentX = 0;
        let isDragging = false;

        this.trackWrapper.addEventListener('touchstart', (e) => {
          startX = e.touches[0].clientX;
          isDragging = true;
        });

        this.trackWrapper.addEventListener('touchmove', (e) => {
          if (!isDragging) return;
          currentX = e.touches[0].clientX;
        });

        this.trackWrapper.addEventListener('touchend', () => {
          if (!isDragging) return;
          const diff = startX - currentX;
          if (Math.abs(diff) > 50) {
            if (diff > 0) {
              this.navigate('next');
            } else {
              this.navigate('prev');
            }
          }
          isDragging = false;
        });
      }

      navigate(direction) {
        const cardsToUse = this.isInfinite ? this.allCards : this.cards;
        const totalCards = cardsToUse.length;

        if (direction === 'next') {
          this.currentIndex++;
        } else {
          this.currentIndex--;
        }

        this.updateSlider();

        if (this.isInfinite) {
          if (this.currentIndex >= totalCards - 3) {
            setTimeout(() => {
              this.track.style.transition = 'none';
              this.currentIndex = 3;
              this.updateSliderPosition();
              setTimeout(() => {
                this.track.style.transition = '';
              }, 50);
            }, 500);
          } else if (this.currentIndex < 0) {
            setTimeout(() => {
              this.track.style.transition = 'none';
              this.currentIndex = totalCards - 7;
              this.updateSliderPosition();
              setTimeout(() => {
                this.track.style.transition = '';
              }, 50);
            }, 500);
          }
        }
      }

      updateSlider() {
        const cardsToUse = this.isInfinite ? this.allCards : this.cards;
        const totalCards = cardsToUse.length;

        if (!this.isInfinite) {
          const maxIndex = Math.max(0, totalCards - this.getVisibleCards());
          this.currentIndex = Math.max(0, Math.min(this.currentIndex, maxIndex));

          this.prevButton.disabled = this.currentIndex === 0;
          this.nextButton.disabled = this.currentIndex >= maxIndex;
        } else {
          this.prevButton.disabled = false;
          this.nextButton.disabled = false;
        }

        this.updateSliderPosition();
      }

      updateSliderPosition() {
        const card = this.isInfinite ? this.allCards[0] : this.cards[0];
        if (!card) return;

        const cardWidth = card.offsetWidth;
        const gap = parseInt(getComputedStyle(this.track).gap) || 0;
        const offset = -(this.currentIndex * (cardWidth + gap));

        this.track.style.transform = `translateX(${offset}px)`;
      }

      getVisibleCards() {
        const width = window.innerWidth;
        if (width <= 749) return 1;
        if (width <= 989) return 2;
        return 3;
      }
    }

    customElements.define('luxury-testimonial-slider-{{ ai_gen_id }}', LuxuryTestimonialSlider{{ ai_gen_id }});
  })();
</script>

